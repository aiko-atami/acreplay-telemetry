{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "native-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "native-debug",
      "displayName": "Native Debug",
      "inherits": "native-base",
      "binaryDir": "${sourceDir}/build/native-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "native-release",
      "displayName": "Native Release",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build/native-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ACRP_ENABLE_ASAN": "OFF",
        "ACRP_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "native-relwithdebinfo",
      "displayName": "Native RelWithDebInfo",
      "inherits": "native-base",
      "binaryDir": "${sourceDir}/build/native-relwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ACRP_ENABLE_ASAN": "OFF",
        "ACRP_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "native-clang-tidy",
      "displayName": "Native Debug + clang-tidy",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build/native-clang-tidy",
      "cacheVariables": {
        "ACRP_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "native-strict",
      "displayName": "Native Debug + warnings as errors",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build/native-strict",
      "cacheVariables": {
        "ACRP_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug"
    },
    {
      "name": "native-release",
      "configurePreset": "native-release"
    },
    {
      "name": "native-relwithdebinfo",
      "configurePreset": "native-relwithdebinfo"
    },
    {
      "name": "native-clang-tidy",
      "configurePreset": "native-clang-tidy"
    },
    {
      "name": "native-strict",
      "configurePreset": "native-strict"
    }
  ],
  "testPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-release",
      "configurePreset": "native-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-relwithdebinfo",
      "configurePreset": "native-relwithdebinfo",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-strict",
      "configurePreset": "native-strict",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "native-debug",
      "steps": [
        {
          "type": "configure",
          "name": "native-debug"
        },
        {
          "type": "build",
          "name": "native-debug"
        },
        {
          "type": "test",
          "name": "native-debug"
        }
      ]
    },
    {
      "name": "native-strict",
      "steps": [
        {
          "type": "configure",
          "name": "native-strict"
        },
        {
          "type": "build",
          "name": "native-strict"
        }
      ]
    },
    {
      "name": "native-clang-tidy",
      "steps": [
        {
          "type": "configure",
          "name": "native-clang-tidy"
        },
        {
          "type": "build",
          "name": "native-clang-tidy"
        }
      ]
    }
  ]
}
