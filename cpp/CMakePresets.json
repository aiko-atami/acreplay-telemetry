{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "native-debug",
      "displayName": "Native Debug",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "native-release",
      "displayName": "Native Release",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ACRP_ENABLE_ASAN": "OFF",
        "ACRP_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "native-clang-tidy",
      "displayName": "Native Debug + clang-tidy",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build-clang-tidy",
      "cacheVariables": {
        "ACRP_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "native-strict",
      "displayName": "Native Debug + warnings as errors",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build-strict",
      "cacheVariables": {
        "ACRP_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug"
    },
    {
      "name": "native-release",
      "configurePreset": "native-release"
    },
    {
      "name": "native-clang-tidy",
      "configurePreset": "native-clang-tidy"
    },
    {
      "name": "native-strict",
      "configurePreset": "native-strict"
    }
  ],
  "testPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-release",
      "configurePreset": "native-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-strict",
      "configurePreset": "native-strict",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
